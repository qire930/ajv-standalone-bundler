{
  "name": "ajv-standalone-bundler",
  "version": "1.0.1",
  "description": "A bundled package combining Ajv and standalone code generator for CDN usage",
  "types": "dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./*": "./*"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "keywords": [
    "ajv"
  ],
  "author": "qire930",
  "license": "MIT",
  "devDependencies": {
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ajv": "^8.18.0"
  }
}
